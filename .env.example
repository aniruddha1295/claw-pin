# claw-pin environment configuration
# Copy this file to .env and fill in your values

# ─── Wallet (generated by `claw-pin init`) ────────────────────────────────────
# Your Ethereum-compatible wallet address (0x...)
WALLET_ADDRESS=0xDc64aAFdAfF0805bB9da2A6cE790bAF594d61109

# Your private key — NEVER commit this! Use .env.wallet instead.
# PRIVATE_KEY=

# ─── Filecoin Network ─────────────────────────────────────────────────────────
# Network: calibration (testnet) or mainnet
FILECOIN_NETWORK=calibration

# Custom RPC URL (optional — defaults to public endpoints)
# RPC_URL=https://api.calibration.node.glif.io/rpc/v1

# ─── Alkahest Escrow (Base Sepolia) ───────────────────────────────────────────
# Base Sepolia RPC for Alkahest escrow transactions
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ─── Debug ────────────────────────────────────────────────────────────────────
# Enable debug logging (set to "true" to show raw error stacks)
DEBUG=false
